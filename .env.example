# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Replace with your MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sarra?retryWrites=true&w=majority

# JWT Secrets - Generate strong random strings (64+ characters)
# Use: openssl rand -base64 64
JWT_SECRET=your-super-strong-jwt-secret-min-64-characters-here
JWT_REFRESH_SECRET=your-super-strong-refresh-secret-min-64-characters-here

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# CORS Allowed Origins (comma-separated for production)
# Example: https://sarra.gov.in,https://dashboard.sarra.gov.in
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001